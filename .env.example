# Helpdesk Automation Toolkit — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ServiceNow API (optional — for live ticket sync)
SNOW_INSTANCE=your-instance.service-now.com
SNOW_USERNAME=api_user
SNOW_PASSWORD=

# Email notification settings (optional)
SMTP_HOST=smtp.company.com
SMTP_PORT=587
SMTP_USER=helpdesk-automation@company.com
SMTP_PASSWORD=

# Slack webhook for SLA breach alerts (optional)
SLACK_WEBHOOK_URL=

# Default SLA evaluation reference (leave blank to use current time)
SLA_REFERENCE_TIMESTAMP=
